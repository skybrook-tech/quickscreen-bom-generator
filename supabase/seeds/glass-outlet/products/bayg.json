  "product_rules": [
    {
      "product_system_type": "BAYG",
      "rule_set_name": "BAYG Fence Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "num_slats",
      "expression": "floor((target_height_mm - slat_gap_mm + 3) / (slat_size_mm + slat_gap_mm))",
      "output_key": "num_slats",
      "priority": 10,
      "active": true,
      "notes": "BAYG uses BAYG_ScrHts VLOOKUP in the CTS spreadsheet. Approximated here with same QSHS formula; engine should override via lookup table when BAYG_ScrHts is seeded."
    },
    {
      "product_system_type": "BAYG",
      "rule_set_name": "BAYG Fence Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "actual_height_mm",
      "expression": "num_slats * (slat_size_mm + slat_gap_mm) - slat_gap_mm + 3",
      "output_key": "actual_height_mm",
      "priority": 20,
      "active": true
    },
    {
      "product_system_type": "BAYG",
      "rule_set_name": "BAYG Fence Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "sf_cut_mm",
      "expression": "actual_height_mm - 3",
      "output_key": "sf_cut_mm",
      "priority": 30,
      "active": true
    },
    {
      "product_system_type": "BAYG",
      "rule_set_name": "BAYG Fence Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "slat_cut_mm",
      "expression": "panel_width_mm - 15",
      "output_key": "slat_cut_mm",
      "priority": 40,
      "active": true
    },
    {
      "product_system_type": "BAYG",
      "rule_set_name": "BAYG Fence Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "num_csr",
      "expression": "panel_width_mm < 2000 ? 0 : panel_width_mm < 4000 ? 1 : panel_width_mm < 6000 ? 2 : 3",
      "output_key": "num_csr",
      "priority": 50,
      "active": true
    },
    {
      "product_system_type": "BAYG",
      "rule_set_name": "BAYG Fence Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "num_sf_left",
      "expression": "left_boundary_type == 'post' ? 1 : 0",
      "output_key": "num_sf_left",
      "priority": 60,
      "active": true
    },
    {
      "product_system_type": "BAYG",
      "rule_set_name": "BAYG Fence Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "num_sf_right",
      "expression": "right_boundary_type == 'post' ? 1 : 0",
      "output_key": "num_sf_right",
      "priority": 70,
      "active": true
    },
    {
      "product_system_type": "BAYG",
      "rule_set_name": "BAYG Fence Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "num_sf_total",
      "expression": "num_sf_left + num_sf_right",
      "output_key": "num_sf_total",
      "priority": 80,
      "active": true
    },
    {
      "product_system_type": "BAYG",
      "rule_set_name": "BAYG Fence Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "num_fsec_total",
      "expression": "(left_boundary_type == 'wall' ? 1 : 0) + (right_boundary_type == 'wall' ? 1 : 0)",
      "output_key": "num_fsec_total",
      "priority": 90,
      "active": true
    },
    {
      "product_system_type": "BAYG",
      "rule_set_name": "BAYG Fence Rules",
      "version_label": "v1.0.0",
      "stage": "stock",
      "name": "slat_cuts_per_stock",
      "expression": "floor(6100 / slat_cut_mm)",
      "output_key": "slat_cuts_per_stock",
      "priority": 10,
      "active": true
    },
    {
      "product_system_type": "BAYG",
      "rule_set_name": "BAYG Fence Rules",
      "version_label": "v1.0.0",
      "stage": "stock",
      "name": "slat_stocks",
      "expression": "ceil(num_slats / slat_cuts_per_stock)",
      "output_key": "slat_stocks",
      "priority": 20,
      "active": true
    },
    {
      "product_system_type": "BAYG",
      "rule_set_name": "BAYG Fence Rules",
      "version_label": "v1.0.0",
      "stage": "stock",
      "name": "sf_stocks",
      "expression": "num_sf_total > 0 ? ceil(num_sf_total / floor(5800 / sf_cut_mm)) : 0",
      "output_key": "sf_stocks",
      "priority": 30,
      "active": true
    },
    {
      "product_system_type": "BAYG",
      "rule_set_name": "BAYG Fence Rules",
      "version_label": "v1.0.0",
      "stage": "stock",
      "name": "csr_stocks",
      "expression": "num_csr > 0 ? ceil(num_csr / floor(5800 / (actual_height_mm - 6))) : 0",
      "output_key": "csr_stocks",
      "priority": 40,
      "active": true
    },
    {
      "product_system_type": "BAYG",
      "rule_set_name": "BAYG Fence Rules",
      "version_label": "v1.0.0",
      "stage": "stock",
      "name": "fsec_stocks",
      "expression": "num_fsec_total > 0 ? ceil(num_fsec_total / floor(5800 / sf_cut_mm)) : 0",
      "output_key": "fsec_stocks",
      "priority": 50,
      "active": true
    },
    {
      "product_system_type": "BAYG",
      "rule_set_name": "BAYG Fence Rules",
      "version_label": "v1.0.0",
      "stage": "accessory",
      "name": "spacer_qty",
      "expression": "2 * (num_slats + 1)",
      "output_key": "spacer_qty",
      "priority": 10,
      "active": true,
      "notes": "BAYG spacers are snap-in, sold individually per-run (not in 50-packs like QSHS). 2*(slats+1) per panel."
    },
    {
      "product_system_type": "BAYG",
