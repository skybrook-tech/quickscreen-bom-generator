      "stage": "component",
      "name": "emit_rails",
      "expression": "rail_stocks",
      "output_key": "qty_rail",
      "priority": 20,
      "active": true,
      "notes": "Top + bottom U-channel rails (QS-5000-HORIZ)"
    },
    {
      "product_system_type": "VS",
      "rule_set_name": "VS Fence Rules",
      "version_label": "v1.0.0",
