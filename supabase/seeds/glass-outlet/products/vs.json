  "product_rules": [
    {
      "product_system_type": "VS",
      "rule_set_name": "VS Fence Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "num_vertical_slats",
      "expression": "floor((panel_width_mm - 8 + slat_gap_mm) / (slat_gap_mm + slat_size_mm))",
      "output_key": "num_vertical_slats",
      "priority": 10,
      "active": true,
      "notes": "VS vertical slat count formula: floor((width - 8 + gap) / (gap + size)). 8mm = channel deduction."
    },
    {
      "product_system_type": "VS",
      "rule_set_name": "VS Fence Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "slat_cut_mm",
      "expression": "target_height_mm",
      "output_key": "slat_cut_mm",
      "priority": 20,
      "active": true,
      "notes": "Vertical slat cut = panel height (full height, slat is XP-6100-S65 / QS-6100-S90 oriented vertically)"
    },
    {
      "product_system_type": "VS",
      "rule_set_name": "VS Fence Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "rail_cut_mm",
      "expression": "panel_width_mm",
      "output_key": "rail_cut_mm",
      "priority": 30,
      "active": true,
      "notes": "Top/bottom rail cut = panel width"
    },
    {
      "product_system_type": "VS",
      "rule_set_name": "VS Fence Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "num_sf_left",
      "expression": "left_boundary_type == 'post' ? 1 : 0",
      "output_key": "num_sf_left",
      "priority": 40,
      "active": true
    },
    {
      "product_system_type": "VS",
      "rule_set_name": "VS Fence Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "num_sf_right",
      "expression": "right_boundary_type == 'post' ? 1 : 0",
      "output_key": "num_sf_right",
      "priority": 50,
      "active": true
    },
    {
      "product_system_type": "VS",
      "rule_set_name": "VS Fence Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "num_sf_total",
      "expression": "num_sf_left + num_sf_right",
      "output_key": "num_sf_total",
      "priority": 60,
      "active": true
    },
    {
      "product_system_type": "VS",
      "rule_set_name": "VS Fence Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "num_fsec_total",
      "expression": "2",
      "output_key": "num_fsec_total",
      "priority": 65,
      "active": true,
      "notes": "VS: always 2 QS-5800-F edge frames per panel (one each side, vertical installation)"
    },
    {
      "product_system_type": "VS",
      "rule_set_name": "VS Fence Rules",
      "version_label": "v1.0.0",
      "stage": "stock",
      "name": "slat_cuts_per_stock",
      "expression": "floor(5800 / slat_cut_mm)",
      "output_key": "slat_cuts_per_stock",
      "priority": 10,
      "active": true,
      "notes": "VS vertical slats are QS-5800-F (F-section) cut to height"
    },
    {
      "product_system_type": "VS",
      "rule_set_name": "VS Fence Rules",
      "version_label": "v1.0.0",
      "stage": "stock",
      "name": "slat_stocks",
      "expression": "ceil(num_vertical_slats / slat_cuts_per_stock)",
      "output_key": "slat_stocks",
      "priority": 20,
      "active": true
    },
    {
      "product_system_type": "VS",
      "rule_set_name": "VS Fence Rules",
      "version_label": "v1.0.0",
      "stage": "stock",
      "name": "rail_cuts_per_stock",
      "expression": "floor(5000 / rail_cut_mm)",
      "output_key": "rail_cuts_per_stock",
      "priority": 30,
      "active": true,
      "notes": "Horizontal rails are QS-5000-HORIZ, 5000mm stock"
    },
    {
      "product_system_type": "VS",
      "rule_set_name": "VS Fence Rules",
      "version_label": "v1.0.0",
      "stage": "stock",
      "name": "rail_stocks",
      "expression": "ceil(2 / rail_cuts_per_stock)",
      "output_key": "rail_stocks",
      "priority": 40,
      "active": true,
      "notes": "2 rails per panel: top + bottom"
    },
    {
      "product_system_type": "VS",
      "rule_set_name": "VS Fence Rules",
      "version_label": "v1.0.0",
      "stage": "stock",
      "name": "sf_stocks",
      "expression": "num_sf_total > 0 ? ceil(num_sf_total / floor(5800 / target_height_mm)) : 0",
      "output_key": "sf_stocks",
      "priority": 50,
      "active": true,
      "notes": "QS-5800-SF used as outer horizontal frame (top+bottom) enclosing U-channel; 2 per panel"
    },
    {
      "product_system_type": "VS",
      "rule_set_name": "VS Fence Rules",
      "version_label": "v1.0.0",
      "stage": "accessory",
      "name": "sfc_qty",
      "expression": "num_sf_total * 2",
      "output_key": "sfc_qty",
      "priority": 10,
      "active": true,
      "notes": "2 QS-SFC-B caps per side frame"
    },
    {
      "product_system_type": "VS",
      "rule_set_name": "VS Fence Rules",
      "version_label": "v1.0.0",
      "stage": "accessory",
      "name": "screw_packs",
      "expression": "ceil(ceil(num_vertical_slats * 1.01 / 10) * 10 / 50)",
      "output_key": "screw_packs",
      "priority": 20,
      "active": true,
      "notes": "VS: ROUNDUP(ROUNDUP(slats*1.01, -1) / 50, 0) \u2014 nearest 10 then 50-packs"
    },
    {
      "product_system_type": "VS",
      "rule_set_name": "VS Fence Rules",
      "version_label": "v1.0.0",
      "stage": "component",
