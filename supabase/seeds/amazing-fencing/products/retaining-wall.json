  "product_rules": [
    {
      "product_system_type": "AF_RETAINING_WALL",
      "rule_set_name": "Amazing Retaining Wall Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "actual_height_mm",
      "expression": "target_height_mm",
      "output_key": "actual_height_mm",
      "priority": 10,
      "active": true
    },
    {
      "product_system_type": "AF_RETAINING_WALL",
      "rule_set_name": "Amazing Retaining Wall Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "post_in_ground_mm",
      "expression": "max(target_height_mm * 0.5, 600)",
      "output_key": "post_in_ground_mm",
      "priority": 20,
      "active": true
    },
    {
      "product_system_type": "AF_RETAINING_WALL",
      "rule_set_name": "Amazing Retaining Wall Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "post_total_length_mm",
      "expression": "target_height_mm + post_in_ground_mm",
      "output_key": "post_total_length_mm",
      "priority": 30,
      "active": true
    },
    {
      "product_system_type": "AF_RETAINING_WALL",
      "rule_set_name": "Amazing Retaining Wall Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "post_stock_length_mm",
      "expression": "equalStrings(product_line, \"superpost\") ? 2400 : (post_total_length_mm <= 1200 ? 1200 : (post_total_length_mm <= 1600 ? 1600 : (post_total_length_mm <= 2000 ? 2000 : (post_total_length_mm <= 2400 ? 2400 : 2400))))",
      "output_key": "post_stock_length_mm",
      "priority": 40,
      "active": true
    },
    {
      "product_system_type": "AF_RETAINING_WALL",
      "rule_set_name": "Amazing Retaining Wall Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "h_post_count",
      "expression": "2 + corner_count",
      "output_key": "h_post_count",
      "priority": 50,
      "active": true
    },
    {
      "product_system_type": "AF_RETAINING_WALL",
      "rule_set_name": "Amazing Retaining Wall Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "c_post_count",
      "expression": "max(0, num_posts - h_post_count)",
      "output_key": "c_post_count",
      "priority": 60,
      "active": true
    },
    {
      "product_system_type": "AF_RETAINING_WALL",
      "rule_set_name": "Amazing Retaining Wall Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "post_caps",
      "expression": "num_posts",
      "output_key": "post_caps",
      "priority": 70,
      "active": true
    },
    {
      "product_system_type": "AF_RETAINING_WALL",
      "rule_set_name": "Amazing Retaining Wall Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "concrete_bags",
      "expression": "num_posts * 2",
      "output_key": "concrete_bags",
      "priority": 80,
      "active": true
    },
    {
      "product_system_type": "AF_RETAINING_WALL",
      "rule_set_name": "Amazing Retaining Wall Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "sleepers_per_bay",
      "expression": "ceil(target_height_mm / sleeper_height_mm)",
      "output_key": "sleepers_per_bay",
      "priority": 90,
      "active": true
    },
    {
      "product_system_type": "AF_RETAINING_WALL",
      "rule_set_name": "Amazing Retaining Wall Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "total_sleepers",
      "expression": "num_panels * sleepers_per_bay",
      "output_key": "total_sleepers",
      "priority": 100,
      "active": true
    },
    {
      "product_system_type": "AF_RETAINING_WALL",
      "rule_set_name": "Amazing Retaining Wall Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "sleepers_with_wastage",
      "expression": "ceil(total_sleepers * 1.05)",
      "output_key": "sleepers_with_wastage",
      "priority": 110,
      "active": true
    },
    {
      "product_system_type": "AF_RETAINING_WALL",
      "rule_set_name": "Amazing Retaining Wall Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "plinth_pieces",
      "expression": "include_plinth ? num_panels : 0",
      "output_key": "plinth_pieces",
      "priority": 120,
      "active": true
    },
    {
      "product_system_type": "AF_RETAINING_WALL",
      "rule_set_name": "Amazing Retaining Wall Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "bracket_pairs",
      "expression": "include_brackets ? h_post_count : 0",
      "output_key": "bracket_pairs",
      "priority": 130,
      "active": true
    },
    {
      "product_system_type": "AF_RETAINING_WALL",
      "rule_set_name": "Amazing Retaining Wall Rules",
      "version_label": "v1.0.0",
      "stage": "derive",
      "name": "bracket_qty",
      "expression": "bracket_pairs * 2",
      "output_key": "bracket_qty",
      "priority": 140,
      "active": true
    }
  ],
