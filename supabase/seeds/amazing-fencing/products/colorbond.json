  "calculator_configs": [
    {
      "product_code": "COLORBOND",
      "notes": "Amazing Fencing Colorbond overlay — source: catalogues/amazing-fencing/. Heights 1200–2400 in 300mm steps; 3 sheets per bay at both bay widths; cap rule ceil(posts/2); runs terminate in C-posts; in-ground mounting only. Components are UNPRICED pending an AF price list. Arrays here REPLACE base arrays (fields, profiles, extraRules). Gates: pre-built GP bundles (SGL/DBL × 900–2100mm) + hardware kits.",
      "config": {
        "heightUi": {
          "mode": "options",
          "heightOptions": [
            1200,
            1500,
            1800,
            2100,
            2400
          ]
        },
        "panelRules": {
          "maxPanelWidthMm": 3100,
          "maxPostSpacingMm": 3200
        },
        "defaults": {
          "targetHeightMm": 1800,
          "colour": "MN",
          "mountingType": "in_ground"
        },
        "extraRules": [
          {
            "id": "af-cbd-fixings-not-calculated",
            "type": "warning",
            "when": {
              "field": "panelWidthMm",
              "op": ">=",
              "value": 0
            },
            "message": "Fixing screws (tek / coloured hex) are not auto-calculated for Amazing Fencing Colorbond — add AF-CBD-SCREW-* items to the quote as extras."
          }
        ],
        "colorbond": {
          "capRule": "half_posts",
          "bayWidths": [
            2360,
            3100
          ],
          "sheetsPerBay": {
            "2360": 3,
            "3100": 3
          },
          "tekPacksPerBay": 0,
          "sheetHeightOffsetMm": 0,
          "postSpacingExtraMm": 0,
          "profiles": [
            {
              "code": "AF-PANEL",
              "skuToken": "PANEL",
              "heights": [
                1200,
                1500,
                1800,
                2100,
                2400
              ]
            }
          ],
          "postHeightByFinished": {
            "1200": {
              "in_ground": 2100
            },
            "1500": {
              "in_ground": 2100
            },
            "1800": {
              "in_ground": 2400
            },
            "2100": {
              "in_ground": 2700
            },
            "2400": {
              "in_ground": 3000
            }
          },
          "cutDownNoteByFinished": {
            "1200": "2100mm C-post cut down 300mm on site (1800mm post height)"
          },
          "terminalPostNote": "C-posts at run ends/corners",
          "skus": {
            "sheet": "AF-CBD-SHEET-{sheetHeight}",
            "rail": "AF-CBD-RAIL-{bayWidth}",
            "channelPost": "AF-CBD-CPOST-{postHeight}",
            "terminalPost": "AF-CBD-CPOST-{postHeight}",
            "capSingle": "AF-CBD-CAP-100x100",
            "capDouble": "AF-CBD-CAP-100x100",
            "tekScrewPack": "AF-CBD-SCREW-TEK-35",
            "sharkfin": "AF-CBD-SHARKFIN-NOT-AVAILABLE",
            "concrete": "AF-CON-POSTMIX-30"
          },
          "gates": {
            "mode": "bundle",
            "bundle": {
              "widthsMm": [
                900,
                1200,
                1500,
                1800,
                2100
              ],
              "singleHardwareKitCodes": [
                "BUTT-HINGE",
                "D-LATCH"
              ],
              "doubleHardwareKitCodes": [
                "DOUBLE-SET"
              ],
              "skus": {
                "gate": "AF-CBD-GATE-STD-{leaf}-{gateWidth}",
                "hardwareKit": "AF-CBD-GATEHW-{kitCode}"
              }
            }
          }
        },
        "fields": [
          {
            "field_key": "colour_code",
            "render_hint": "colour",
            "label": "Colour",
            "group": "colour",
            "control_type": "colour_palette",
            "data_type": "enum",
            "required": true,
            "default_value_json": "MN",
            "options_json": [],
