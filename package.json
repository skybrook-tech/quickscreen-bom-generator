{
  "name": "quickscreen-bom-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "20.x",
    "npm": "10.8.x"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "build": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "serve:html": "npx serve 'Desktop/Claude Glass Outlet Project' -p 3124",
    "cy:open": "CYPRESS_BASE_URL=http://localhost:5173 cypress open",
    "cy:run": "CYPRESS_BASE_URL=http://localhost:5173 cypress run",
    "cy:run:html": "CYPRESS_IS_HTML_APP=true CYPRESS_BASE_URL=http://localhost:3124 cypress run",
    "cy:run:react": "CYPRESS_BASE_URL=http://localhost:5173 cypress run",
    "test": "vitest run --environment jsdom src/hooks/useGoogleMaps.test.tsx",
    "test:lib": "vitest run --environment jsdom src/lib/multiSupplier src/lib/pricing",
    "test:rls": "npx deno test --allow-net --allow-env supabase/tests/rls_matrix_test.ts",
    "test:e2e": "npm run cy:run",
    "test:unit": "npx deno test --allow-read --allow-env supabase/functions/bom-calculator/index_test.ts",
    "test:integration": "scripts/test-integration.sh",
    "test:describe-fence": "node scripts/run-describe-fence-parser-tests.mjs",
    "seed:auth": "node supabase/seeds/seed-auth.js",
    "seed:glass-outlet": "node supabase/seeds/glass-outlet/seed-images.js",
    "seed:products": "node supabase/seeds/tools/seed-products.js",
    "seed:products:remote": "NODE_ENV=production node supabase/seeds/tools/seed-products.js",
    "prices:import": "node scripts/import-glassoutlet-prices.mjs",
    "prices:brief-at": "node scripts/build-brief-at-pricing-seed.mjs",
    "seed:dump": "node supabase/seeds/tools/dump-to-json.js",
    "db:reset": "npx supabase@2.104.0 db reset && npm run seed:products && npm run seed:auth",
    "db:push-remote": "npx supabase@latest db push",
    "db:seed-remote": "npm run db:push-remote && npm run seed:products:remote",
    "setup": "npx supabase@2.104.0 start && npm run db:reset"
  },
  "devDependencies": {
    "@types/google.maps": "^3.64.1",
    "@types/papaparse": "^5.5.2",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.27",
    "cypress": "^15.15.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.8",
    "serve": "^14.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2",
    "vite": "^5.4.21",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@floating-ui/react": "^0.27.19",
    "@googlemaps/js-api-loader": "^1.16.10",
    "@hookform/resolvers": "^5.2.2",
    "@react-pdf/renderer": "^4.3.3",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.96.2",
    "clsx": "^2.1.1",
    "color-contrast": "^1.0.0",
    "dotenv": "^17.4.0",
    "lucide-react": "^1.7.0",
    "papaparse": "^5.5.3",
    "pluralize": "^8.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  }
}