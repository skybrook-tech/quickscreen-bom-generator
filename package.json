{
  "name": "quickscreen-bom-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "serve:html": "npx serve 'Desktop/Claude Glass Outlet Project' -p 3124",
    "cy:open": "CYPRESS_BASE_URL=http://localhost:5173 cypress open",
    "cy:run": "CYPRESS_BASE_URL=http://localhost:5173 cypress run",
    "cy:run:html": "CYPRESS_IS_HTML_APP=true CYPRESS_BASE_URL=http://localhost:3124 cypress run",
    "cy:run:react": "CYPRESS_BASE_URL=http://localhost:5173 cypress run",
    "test": "npm run cy:run",
    "seed:auth": "node supabase/seeds/seed-auth.js",
    "seed:glass-outlet": "node supabase/seeds/glass-outlet/seed-images.js",
    "db:reset": "npx supabase db reset && npm run seed:auth && npm run seed:glass-outlet",
    "setup": "npx supabase start && npm run db:reset"
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.2",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "cypress": "^13.17.0",
    "postcss": "^8.5.8",
    "serve": "^14.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-pdf/renderer": "^4.3.3",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.96.2",
    "dotenv": "^17.4.0",
    "lucide-react": "^1.7.0",
    "papaparse": "^5.5.3",
    "pluralize": "^8.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.0",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  }
}
